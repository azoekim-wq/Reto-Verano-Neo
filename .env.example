# Copia este fichero a .env.local y rellena con tus credenciales de Firebase.
# Se obtienen en Firebase Console > ⚙️ Project settings > General > Your apps > SDK setup and configuration > Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Documento bajo /retos/{VITE_RETO_ID}/participantes/*
VITE_RETO_ID=reto-verano-2024

# Modo de datos: 'firebase' (producción) o 'mock' (datos ficticios para desarrollo sin backend)
VITE_DATA_MODE=firebase
